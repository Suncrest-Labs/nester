# Runtime environment: development, staging, production, or test.
APP_ENV=development

# HTTP server host interface.
SERVER_HOST=0.0.0.0

# HTTP server port.
SERVER_PORT=8080

# Maximum duration for reading the full request, including body.
SERVER_READ_TIMEOUT=15s

# Maximum duration before timing out response writes.
SERVER_WRITE_TIMEOUT=15s

# Time allowed for graceful shutdown before forcefully stopping.
SERVER_SHUTDOWN_TIMEOUT=20s

# PostgreSQL connection string used by the API.
DATABASE_DSN=postgres://postgres:postgres@localhost:5432/nester?sslmode=disable

# Maximum number of open PostgreSQL connections in the pool.
DATABASE_POOL_SIZE=25

# Timeout used when opening the initial database connection and pinging.
DATABASE_CONNECTION_TIMEOUT=5s

# Stellar network passphrase.
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban RPC endpoint.
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Horizon API endpoint.
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# JWT issuer used in access and refresh tokens.
AUTH_JWT_ISSUER=nester-api

# HMAC secret for short-lived access tokens.
AUTH_JWT_ACCESS_SECRET=replace-with-32-byte-secret

# HMAC secret for refresh tokens and session rotation.
AUTH_JWT_REFRESH_SECRET=replace-with-32-byte-secret

# Access token lifetime.
AUTH_ACCESS_TOKEN_TTL=15m

# Refresh token lifetime.
AUTH_REFRESH_TOKEN_TTL=168h

# Nonce lifetime for wallet sign-in.
AUTH_NONCE_TTL=5m

# Log level: debug, info, warn, or error.
LOG_LEVEL=info

# Log output format: text or json. Defaults to text outside production/staging.
LOG_FORMAT=text
